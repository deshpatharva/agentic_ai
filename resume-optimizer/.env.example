# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-32-char-random-string

# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/resumeopt

# LLM provider keys
# NOTE: env var names are case-sensitive on Linux/macOS — use the exact uppercase
# names below. config.py reads GOOGLE_AI_STUDIO_API_KEY (or GEMINI_API_KEY /
# GOOGLE_API_KEY) and GROQ_API_KEY.
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_STUDIO_API_KEY=AIza...
GROQ_API_KEY=gsk_...
# DeepSeek strategist model (Phase 2 optimizer). Optional — falls back per config.py.
DEEPSEEK_API_KEY=sk-...

# ── Optional — job scraper sources ────────────────────────────────────────────
# Sources are skipped when the key is absent; no errors thrown.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
THE_MUSE_API_KEY=
APIFY_TOKEN=

# ── Optional — billing ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# ── Optional — deployment overrides ──────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Delta Lake storage path (local dev default; set to abfs:// or s3:// in prod)
DELTA_STORAGE_PATH=./delta_store

# Input guards (defaults shown; override as needed)
MAX_UPLOAD_BYTES=5242880
MAX_RESUME_CHARS=15000
MAX_JD_CHARS=8000
