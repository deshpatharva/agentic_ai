# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

# Find your subscription ID:
#   az account show --query id -o tsv
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Short prefix — used in all resource names (must be globally unique for storage/keyvault)
# e.g. "resumai" + "st" + "dev" = "resumaistdev" (storage account name)
prefix      = "resumai"
environment = "dev"
location    = "eastus"

# PostgreSQL
postgres_admin_login = "resumeadmin"
postgres_db_name     = "resumeopt"

# API keys / secrets are NO LONGER Terraform variables. Seed them directly into
# Key Vault out-of-band so rotation never needs a terraform apply:
#   ./seed-secrets.sh   (wraps `az keyvault secret set`)
# Secrets to seed: GOOGLE-AI-STUDIO-API-KEY, GROQ-API-KEY, DEEPSEEK-API-KEY,
#   ANTHROPIC-API-KEY, BOOTSTRAP-SECRET, and optionally STRIPE-SECRET-KEY,
#   ADZUNA-APP-ID, ADZUNA-APP-KEY, THE-MUSE-API-KEY, APIFY-TOKEN.

# Optional model toggles (defaults: deepseek/deepseek-v4-pro, max):
# model_optimizer           = "deepseek/deepseek-v4-pro"
# deepseek_reasoning_effort = "max"
