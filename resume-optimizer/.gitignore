# ── Runtime artifacts (never commit) ─────────────────────────────────────────
backend/uploads/
backend/outputs/
backend/delta_store/

# ── Frontend build artifacts ──────────────────────────────────────────────────
frontend/node_modules/
frontend/.vite/
frontend/dist/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
*.env

# ── Terraform ────────────────────────────────────────────────────────────────
infra/terraform.tfvars
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/*.tfplan

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
rv/
*.superpowers/

# ── Test databases (ephemeral — never commit) ─────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Delta Lake test artifacts ─────────────────────────────────────────────────
delta_store/
