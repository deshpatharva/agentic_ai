# ── Runtime artifacts (never commit) ─────────────────────────────────────────
backend/uploads/
backend/outputs/
backend/delta_store/

# ── Frontend build artifacts ──────────────────────────────────────────────────
frontend/node_modules/
frontend/.vite/
frontend/dist/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
*.env

# ── Terraform ────────────────────────────────────────────────────────────────
infra/terraform.tfvars
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/*.tfplan

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.superpowers/
